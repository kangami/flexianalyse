# ============================================================================
# MCP Server HTTP Streaming Transport Configuration
# ============================================================================

# HTTP Host and Ports for all servers (inside containers)
# These are configured in each Dockerfile
# External ports are mapped in docker-compose.yml

# SQL Server HTTP Configuration
# External: http://localhost:3001
# Internal: http://0.0.0.0:3001
HTTP_HOST_SQL=0.0.0.0
HTTP_PORT_SQL=3001

# Google Drive Server HTTP Configuration
# External: http://localhost:3002
# Internal: http://0.0.0.0:3002
HTTP_HOST_GOOGLE_DRIVE=0.0.0.0
HTTP_PORT_GOOGLE_DRIVE=3002

# SharePoint Server HTTP Configuration
# External: http://localhost:3003
# Internal: http://0.0.0.0:3003
HTTP_HOST_SHAREPOINT=0.0.0.0
HTTP_PORT_SHAREPOINT=3003

# ============================================================================
# SQL Server Configuration
# ============================================================================

# Connection string examples:
# PostgreSQL: postgresql://user:password@localhost:5432/dbname
# MySQL: mysql+mysqlconnector://user:password@localhost:3306/dbname
# Oracle: oracle://user:password@localhost:1521/dbname

DATABASE_URL=postgresql://postgres:password@postgres:5432/bugmentor

# PostgreSQL credentials (for docker-compose postgres service)
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=bugmentor

# ============================================================================
# Google Drive Server Configuration
# ============================================================================

# Path to Google service account JSON file
# Download from: Google Cloud Console > Service Accounts
GOOGLE_SERVICE_ACCOUNT_PATH=./secrets/google-service-account.json

# ============================================================================
# SharePoint Server Configuration
# ============================================================================

# SharePoint site URL
# Format: https://tenant.sharepoint.com/sites/sitename
SHAREPOINT_SITE_URL=https://tenant.sharepoint.com/sites/sitename

# Azure AD Application Registration credentials
# Create in: Azure Portal > App Registrations
SHAREPOINT_CLIENT_ID=your-client-id-here
SHAREPOINT_CLIENT_SECRET=your-client-secret-here

# ============================================================================
# Docker Compose Configuration
# ============================================================================

# Compose project name
COMPOSE_PROJECT_NAME=bugmentor-mcp

# Enable SSL/TLS with reverse proxy (optional)
# Recommended for production: Configure nginx/traefik for SSL termination
# COMPOSE_HTTPS_ENABLED=true
# COMPOSE_SSL_CERT_PATH=./certs/server.crt
# COMPOSE_SSL_KEY_PATH=./certs/server.key

EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
