VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_API_URL=http://localhost:5000

# Backend Firebase Admin
FIREBASE_SERVICE_ACCOUNT_PATH=backend/firebase-service-account.json
# Optional alternative to FIREBASE_SERVICE_ACCOUNT_PATH
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Backend PostgreSQL + pgvector
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/flexidb
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=flexidb
PG_USER=postgres
PG_PASSWORD=postgres
EMBEDDING_DIMENSION=1536

# AWS persistence (metadata in PostgreSQL + raw documents in S3)
AWS_STORAGE_ENABLED=false
AWS_REGION=us-east-2
AWS_S3_BUCKET_DOCUMENTS=your-documents-bucket
