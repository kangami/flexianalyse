VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_API_URL=http://localhost:5000

# Backend Firebase Admin
FIREBASE_SERVICE_ACCOUNT_PATH=backend/firebase-service-account.json
# Optional alternative to FIREBASE_SERVICE_ACCOUNT_PATH
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Backend PostgreSQL + pgvector
DATABASE_URL=postgresql://postgresUser:postgresPassword@localhost:5432/dbname
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=dbname
PG_USER=postgresUser
PG_PASSWORD=postgres
EMBEDDING_DIMENSION=1536

# MCP Connector server URLs  (must match docker-compose.yml ports)
SQL_MCP_URL=http://localhost:3001
GOOGLE_DRIVE_MCP_URL=http://localhost:3002
SHAREPOINT_MCP_URL=http://localhost:3003
DROPBOX_MCP_URL=http://localhost:3004

# Google OAuth 2.0  (console.cloud.google.com → Credentials → OAuth 2.0 Client IDs)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google_drive/callback

# Microsoft OAuth 2.0  (portal.azure.com → App Registrations)
MS_CLIENT_ID=your-ms-client-id
MS_CLIENT_SECRET=your-ms-client-secret
MS_TENANT_ID=common
MS_REDIRECT_URI=http://localhost:5000/auth/sharepoint/callback

# Dropbox OAuth 2.0  (dropbox.com/developers → App Console → create app)
DROPBOX_CLIENT_ID=your-dropbox-app-key
DROPBOX_CLIENT_SECRET=your-dropbox-app-secret
DROPBOX_REDIRECT_URI=http://localhost:5000/auth/dropbox/callback

# Frontend URL (used for post-OAuth redirects)
FRONTEND_URL=http://localhost:5173

# AWS persistence (metadata in PostgreSQL + raw documents in S3)
AWS_STORAGE_ENABLED=false
AWS_REGION=us-east-2
AWS_S3_BUCKET_DOCUMENTS=your-documents-bucket
