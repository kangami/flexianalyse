# Frontend env vars for the Vercel deployment.
# Set these in Vercel → Project → Settings → Environment Variables.
# Only VITE_* vars are exposed to the browser bundle — never put backend secrets here.

# Public URL of your deployed Flask backend (no trailing slash).
# The frontend calls <VITE_API_URL>/query, /upload, /models, /api/v2/*, etc.
VITE_API_URL=https://flexianalyse.com

# Firebase web app config (safe to expose — these are public client keys).
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
